{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["entity_types", "relationship_types"],
  "additionalProperties": false,
  "properties": {
    "entity_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description"],
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string"
          }
        }
      }
    },
    "relationship_types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "source_types", "target_types"],
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string"
          },
          "source_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
