{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Extraction of relationships between entities",
  "type": "object",
  "required": ["relationships"],
  "additionalProperties": false,
  "properties": {
    "relationships": {
      "type": "array",
      "description": "List of all relationships detected in the document.",
      "items": {
        "type": "object",
        "required": ["name", "source", "target"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "description": "The type of the relationship, e.g. 'WORKS_FOR', 'LOCATED_IN', 'CONNECTED_TO', etc."
          },
          "source": {
            "type": "string",
            "description": "The name of the source entity"
          },
          "target": {
            "type": "string",
            "description": "The name of the target entity"
          }
        }
      }
    }
  }
}
